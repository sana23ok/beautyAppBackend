# Copy this file to .env in the same folder (beauty_app_backend/) and fill in values.
# The real .env file is gitignored — never commit it.

# PostgreSQL (required)
POSTGRES_DB=beautydb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# Cloudinary (profile photo upload) — https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Optional: instead of the three lines above, you can use one URL from the Cloudinary dashboard:
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
