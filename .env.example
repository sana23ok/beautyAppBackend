# Copy this file to .env in the same folder (beauty_app_backend/) and fill in values.
# The real .env file is gitignored — never commit it.

# --- PostgreSQL: local development ---
# POSTGRES_DB=beautydb
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=your_postgres_password
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5433

# --- PostgreSQL: Render (uncomment and fill when deploying) ---
# POSTGRES_DB=beautydb_xxxx
# POSTGRES_USER=root
# POSTGRES_PASSWORD=your_render_db_password
# POSTGRES_HOST=dpg-xxxxxxxx.oregon-postgres.render.com
# POSTGRES_PORT=5432
# POSTGRES_SSL=require

# Cloudinary (profile photo upload) — https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Optional: instead of the three lines above, you can use one URL from the Cloudinary dashboard:
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Google Sign-In — OAuth 2.0 Web application client (Google Cloud Console → Credentials).
# WEB_CLIENT_ID is required to verify Google Sign-In idTokens from the Android app.
# It must match BeautyAppFrontend/local.properties → WEB_CLIENT_ID.
# WEB_CLIENT_SECRET is optional (only used for server-side authorization-code exchange).
WEB_CLIENT_ID=your_web_client_id.apps.googleusercontent.com
WEB_CLIENT_SECRET=your_web_client_secret

# Email verification (Gmail SMTP example; use a Google app password, not account password).
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_gmail_address@gmail.com
EMAIL_HOST_PASSWORD=your_google_app_password_without_spaces
DEFAULT_FROM_EMAIL=your_gmail_address@gmail.com
